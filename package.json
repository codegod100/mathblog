{
	"name": "mathblog-obsidian",
	"version": "0.1.0",
	"description": "Publish Obsidian notes as site.standard.document on AT Protocol, with KaTeX math support.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node build-css.mjs",
