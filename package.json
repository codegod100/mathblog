		"katex": "^0.16.45",
		"marked": "^18.0.2"
	},
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"vitest": "^2.1.9"
	}
}
